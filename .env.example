# ═══════════════════════════════════════════════════════
# WHALEMON TCG — Oracle Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in the values

# Required: Private key of the oracle wallet
# This wallet must be set as the oracle on the WhaleCards contract
ORACLE_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Required: Deployed WhaleCards contract address on Tempo
WHALE_CARDS_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS

# Optional: BattleArena and Marketplace addresses (for extended oracle features)
BATTLE_ARENA_ADDRESS=0x_YOUR_BATTLE_ARENA_ADDRESS
MARKETPLACE_ADDRESS=0x_YOUR_MARKETPLACE_ADDRESS

# Optional: Tempo RPC URL (defaults to public endpoint)
TEMPO_RPC=https://rpc.tempo.xyz

# Optional: Anthropic API key for AI-generated abilities
# If not set, fallback abilities will be used
ANTHROPIC_API_KEY=sk-ant-_YOUR_API_KEY_HERE

# Optional: Path to store card metadata JSON files
METADATA_STORE_PATH=./metadata

# Optional: Port for the metadata API server
METADATA_API_PORT=3001
